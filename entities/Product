{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Price in USD"
    },
    "sale_price": {
      "type": "number",
      "description": "Sale price (overrides price when active)"
    },
    "sale_ends_at": {
      "type": "string",
      "format": "date-time",
      "description": "Sale expiry datetime"
    },
    "on_sale": {
      "type": "boolean",
      "default": false,
      "description": "Is product on sale"
    },
    "category": {
      "type": "string",
      "description": "Category key (custom, from categories table)"
    },
    "collection": {
      "type": "string",
      "description": "Collection name"
    },
    "sizes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available sizes"
    },
    "size_stock": {
      "type": "object",
      "description": "Stock per size: {S: 10, M: 5}"
    },
    "colors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available colors"
    },
    "color_images": {
      "type": "object",
      "description": "Image per color: {Navy: 'url', Black: 'url'}"
    },
    "image_url": {
      "type": "string",
      "description": "Primary product image"
    },
    "lifestyle_image_url": {
      "type": "string",
      "description": "Lifestyle/secondary image"
    },
    "extra_images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Additional gallery images"
    },
    "video_url": {
      "type": "string",
      "description": "Product video URL shown in gallery"
    },
    "stock": {
      "type": "number",
      "description": "Total stock quantity"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Featured on homepage"
    },
    "style_guide": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Styling suggestions"
    },
    "fabric": {
      "type": "string",
      "description": "Fabric composition"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "archived"
      ],
      "default": "active"
    }
  },
  "required": [
    "name",
    "price",
    "category"
  ]
}

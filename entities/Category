{
  "name": "Category",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "URL-safe key e.g. old_money"
    },
    "label": {
      "type": "string",
      "description": "Display label e.g. Old Money"
    },
    "description": {
      "type": "string",
      "description": "Short category description"
    },
    "cover_image_url": {
      "type": "string",
      "description": "Category cover image"
    },
    "on_sale": {
      "type": "boolean",
      "default": false,
      "description": "All products in this category on sale"
    },
    "sale_discount_pct": {
      "type": "number",
      "description": "Discount percentage for category sale (e.g. 20 = 20% off)"
    },
    "sale_ends_at": {
      "type": "string",
      "format": "date-time",
      "description": "Category sale expiry"
    },
    "sort_order": {
      "type": "number",
      "default": 0,
      "description": "Display order in nav/shop"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "hidden"
      ],
      "default": "active"
    }
  },
  "required": [
    "key",
    "label"
  ]
}
